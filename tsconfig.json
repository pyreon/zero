{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@pyreon/core",
    "outDir": "./lib",
    "rootDir": "./src",
    "types": ["vitest/globals", "node"]
  },
  "exclude": ["node_modules", "lib", "dist"]
}

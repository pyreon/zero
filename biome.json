{
  "$schema": "https://biomejs.dev/schemas/2.1.2/schema.json",
  "extends": ["@vitus-labs/tools-lint/biome"],
  "files": {
    "includes": ["packages/**", "!**/lib/**", "!**/dist/**"]
  },
  "overrides": [
    {
      "includes": ["packages/cli/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/create-zero/src/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/create-zero/templates/**"],
      "javascript": {
        "globals": ["__ZERO_MODE__", "__ZERO_BASE__"]
      }
    },
    {
      "includes": ["packages/zero/src/**/*.tsx"],
      "linter": {
        "rules": {
          "correctness": {
            "useHookAtTopLevel": "off",
            "noChildrenProp": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/zero/src/image-plugin.ts"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    }
  ]
}

{
  "name": "pyreon-zero",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "dev": "bun run --filter='*' dev",
    "test": "bun run --filter='*' test",
    "typecheck": "bun run --filter='*' typecheck",
    "test:template": "bash scripts/test-template.sh",
    "version-packages": "changeset version",
    "release": "bun run build && bun run scripts/publish.ts"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@clack/core": "^1.1.0",
    "@clack/prompts": "^1.1.0",
    "@pyreon/typescript": "^0.7.12",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@vitus-labs/tools-lint": "^1.15.4",
    "@vitus-labs/tools-rolldown": "^1.15.4",
    "@vitus-labs/tools-typescript": "^1.15.4",
    "@vitus-labs/tools-vitest": "^1.15.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}

{
  "name": "pyreon-zero",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter='*' build",
    "dev": "bun run --filter='*' dev",
    "test": "bun run --filter='*' test",
    "typecheck": "bun run --filter='*' typecheck"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.4",
    "@types/bun": "^1.3.10",
    "@vitus-labs/tools-lint": "latest",
    "@vitus-labs/tools-rolldown": "latest",
    "@vitus-labs/tools-typescript": "latest",
    "@vitus-labs/tools-vitest": "latest",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "@pyreon/reactivity": "file:../pyreon/packages/reactivity",
    "@pyreon/core": "file:../pyreon/packages/core",
    "@pyreon/runtime-dom": "file:../pyreon/packages/runtime-dom",
    "@pyreon/runtime-server": "file:../pyreon/packages/runtime-server",
    "@pyreon/router": "file:../pyreon/packages/router",
    "@pyreon/head": "file:../pyreon/packages/head",
    "@pyreon/server": "file:../pyreon/packages/server",
    "@pyreon/vite-plugin": "file:../pyreon/packages/vite-plugin",
    "@pyreon/store": "file:../fundamentals/packages/store"
  }
}
 